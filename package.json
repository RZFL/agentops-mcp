{
  "name": "agentops-mcp",
  "version": "1.0.0",
  "description": "Local-first MCP safety agent for AI coding workflows with action review, checkpoints, and rollback.",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=10"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "verify": "npm run check && npm test",
    "demo:security": "node dist/scripts/security-demo.js",
    "demo:inspector": "py -3 ./inspector/agent_component_inspector.py --no-gui --json",
    "demo:workflow": "node dist/scripts/guardian-workflow-demo.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/sqlite3": "^3.1.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
